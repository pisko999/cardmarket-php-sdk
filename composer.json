{
    "name": "pisko999/cardmarket-php-sdk",
    "description": "Wrap Cardmarket API with PHP",
    "keywords": ["api", "wrapper", "cardmarket", "cardmarket-php-sdk", "sdk"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Nicolas Perussel",
            "email": "nicolas.perussel@gmail.com"
        },
        {
            "name": "Petr Spinar",
            "email": "spinarp@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {"Pisko\\CardMarket\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {
            "Pisko\\CardMarket\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "symfony/http-client": "^5.1",
        "webmozart/assert": "^1.9",
        "spatie/macroable": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.10",
        "symfony/var-dumper": "^5.1",
        "friendsofphp/php-cs-fixer": "^3.65",
        "dg/bypass-finals": "^1.2",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse",
        "test-coverage": "vendor/bin/phpunit --coverage-text --coverage-clover=build/coverage.xml",
        "test-coverage-html": "vendor/bin/phpunit --coverage-text --coverage-html=build",
        "check": [
            "@cs-check",
            "@stan",
            "@test"
        ],
        "e2e": "php e2e/run-tests.php",
        "e2e:games": "php e2e/run-tests.php --suite=games",
        "e2e:products": "php e2e/run-tests.php --suite=products",
        "e2e:stock": "php e2e/run-tests.php --suite=stock",
        "e2e:orders": "php e2e/run-tests.php --suite=orders",
        "e2e:wantslists": "php e2e/run-tests.php --suite=wantslists",
        "e2e:account": "php e2e/run-tests.php --suite=account"
    }
}
