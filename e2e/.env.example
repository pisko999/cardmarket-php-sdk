# Cardmarket API Credentials
# Get your credentials at: https://www.cardmarket.com/en/Magic/Account/API
#
# WARNING: These tests run against the LIVE Cardmarket API!
# Use a dedicated test account with limited stock/funds.

# Your application token
CARDMARKET_APP_TOKEN=

# Your application secret
CARDMARKET_APP_SECRET=

# Your access token (OAuth)
CARDMARKET_ACCESS_TOKEN=

# Your access secret (OAuth)
CARDMARKET_ACCESS_SECRET=

# Test configuration
# Game ID for testing (1 = Magic: The Gathering)
TEST_GAME_ID=1

# Product ID for testing (use a common card)
TEST_PRODUCT_ID=273799

# Expansion ID for testing
TEST_EXPANSION_ID=1525

# Your own user ID (for account tests)
TEST_USER_ID=

# Another user ID for testing (e.g., for articles/messages)
TEST_OTHER_USER_ID=

# Username to search for in findUsers test
TEST_SEARCH_USERNAME=

# Enable destructive tests
# Only set these to true if you understand the consequences!
# These operations modify real data on your Cardmarket account.

# Enable message sending tests (will send real messages)
ENABLE_MESSAGE_TESTS=false

# Enable cart modification tests (will modify your cart)
ENABLE_CART_TESTS=false

# Enable cart cleanup (will empty your cart after tests)
ENABLE_CART_CLEANUP=false

# Enable vacation toggle test (will temporarily change your vacation status)
ENABLE_VACATION_TESTS=false
